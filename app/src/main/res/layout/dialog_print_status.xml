<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@drawable/bg_spinner_box"
    android:backgroundTint="@color/bg_slate_card"
    android:minWidth="280dp">

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/printProgressIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        app:indicatorColor="@color/accent_blue"
        app:trackColor="@color/border_glass"
        app:trackThickness="4dp"
        app:indicatorSize="48dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvPrintMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mengirim ke printer..."
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:gravity="center" />

</LinearLayout>
