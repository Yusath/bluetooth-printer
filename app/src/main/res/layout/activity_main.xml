<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_slate_dark"
    android:padding="16dp">

    <!-- Scrollable tab content -->
    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER PANEL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="20dp">

                <!-- Glowing circular container for the header icon -->
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_spinner_box"
                    android:layout_marginBottom="12dp">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_printer"
                        app:tint="@color/accent_blue"
                        android:contentDescription="@string/app_name"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Web &amp; TCP Print Bridge"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>

            <!-- BLUETOOTH STATUS WARNING BANNER -->
            <LinearLayout
                android:id="@+id/llBluetoothWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_status_disconnected"
                android:padding="14dp"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_scan"
                    app:tint="@color/status_red"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Warning"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/bt_turned_off"
                    android:textColor="@color/status_red"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <!-- ==================== TAB 1: PRINTER CONNECTION ==================== -->
            <LinearLayout
                android:id="@+id/tabLayoutPrinter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_glass"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/bg_slate_card"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_scan"
                                app:tint="@color/accent_blue"
                                android:layout_marginEnd="12dp"
                                android:contentDescription="@string/printer_settings"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="@string/printer_settings"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <!-- Status Display Pill Badge -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/status_printer"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:layout_marginEnd="12dp"
                                android:fontFamily="sans-serif"/>

                            <TextView
                                android:id="@+id/tvPrinterStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Disconnected"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"
                                android:background="@drawable/bg_status_disconnected"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/select_printer"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="sans-serif-medium"/>

                        <!-- Custom Spinner container with Chevron -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_spinner_box"
                            android:layout_marginBottom="20dp">

                            <Spinner
                                android:id="@+id/spPrinters"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:spinnerMode="dropdown"
                                android:paddingStart="12dp"
                                android:paddingEnd="40dp"
                                android:background="@android:color/transparent"
                                android:textColor="@color/text_primary"/>
                            
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="14dp"
                                android:src="@drawable/ic_arrow_down"
                                app:tint="@color/text_secondary"
                                android:contentDescription="Dropdown Arrow"
                                android:clickable="false"
                                android:focusable="false"/>
                        </FrameLayout>

                        <!-- Primary Connect Action Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnConnect"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:text="@string/connect"
                            android:textColor="#0B0F19"
                            app:backgroundTint="@color/accent_blue"
                            app:cornerRadius="25dp"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginBottom="16dp"
                            android:fontFamily="sans-serif-medium"/>

                        <!-- Side-by-Side Test Printing Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTestPrint"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="48dp"
                                android:text="Test Text"
                                android:textColor="@color/accent_blue"
                                app:strokeColor="@color/accent_blue"
                                app:strokeWidth="1.5dp"
                                app:cornerRadius="24dp"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp"
                                android:fontFamily="sans-serif-medium"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTestImagePrint"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="48dp"
                                android:text="Test Image"
                                android:textColor="@color/accent_blue"
                                app:strokeColor="@color/accent_blue"
                                app:strokeWidth="1.5dp"
                                app:cornerRadius="24dp"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:layout_marginStart="6dp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ==================== TAB 2: SERVER SETTINGS ==================== -->
            <LinearLayout
                android:id="@+id/tabLayoutServer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_glass"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/bg_slate_card"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_server"
                                app:tint="@color/accent_blue"
                                android:layout_marginEnd="12dp"
                                android:contentDescription="@string/server_settings"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="@string/server_settings"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <!-- Status Display Pill Badge -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/status_server"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:layout_marginEnd="12dp"
                                android:fontFamily="sans-serif"/>

                            <TextView
                                android:id="@+id/tvServerStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Stopped"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"
                                android:background="@drawable/bg_status_disconnected"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <!-- Switches & Inputs -->
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swStartServer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/enable_server"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            app:useMaterialThemeColors="false"
                            app:thumbTint="@color/accent_blue"
                            app:trackTint="@color/border_glass"
                            android:layout_marginBottom="16dp"
                            android:fontFamily="sans-serif-medium"/>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swStartOnBoot"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/start_on_boot"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            app:useMaterialThemeColors="false"
                            app:thumbTint="@color/accent_blue"
                            app:trackTint="@color/border_glass"
                            android:layout_marginBottom="20dp"
                            android:fontFamily="sans-serif-medium"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="@string/server_port"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <EditText
                                android:id="@+id/etServerPort"
                                android:layout_width="110dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_spinner_box"
                                android:gravity="center"
                                android:inputType="number"
                                android:text="6801"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:maxLength="5"
                                android:padding="8dp"
                                android:contentDescription="@string/server_port"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ==================== TAB 3: ADVANCED SETTINGS ==================== -->
            <LinearLayout
                android:id="@+id/tabLayoutSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_glass"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/bg_slate_card"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_settings"
                                app:tint="@color/accent_blue"
                                android:layout_marginEnd="12dp"
                                android:contentDescription="Advanced Settings"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="Advanced Settings"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <!-- Auto Update Switch & Action button inline layout -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">
                            
                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/swAutoUpdate"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_update"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                app:useMaterialThemeColors="false"
                                app:thumbTint="@color/accent_blue"
                                app:trackTint="@color/border_glass"
                                android:fontFamily="sans-serif-medium"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCheckUpdate"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="Check"
                                android:textColor="@color/accent_blue"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <!-- Buffer Throttling Switch -->
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swBufferThrottle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/buffer_throttle"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            app:useMaterialThemeColors="false"
                            app:thumbTint="@color/accent_blue"
                            app:trackTint="@color/border_glass"
                            android:layout_marginBottom="20dp"
                            android:fontFamily="sans-serif-medium"/>

                        <!-- Paper Size Option with custom Spinner box -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="@string/paper_size"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <FrameLayout
                                android:layout_width="150dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_spinner_box">

                                <Spinner
                                    android:id="@+id/spPaperSize"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:spinnerMode="dropdown"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="36dp"
                                    android:background="@android:color/transparent"
                                    android:textColor="@color/text_primary"/>

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="end|center_vertical"
                                    android:layout_marginEnd="10dp"
                                    android:src="@drawable/ic_arrow_down"
                                    app:tint="@color/text_secondary"
                                    android:contentDescription="Dropdown Arrow"
                                    android:clickable="false"
                                    android:focusable="false"/>
                            </FrameLayout>
                        </LinearLayout>

                        <!-- Extra Feed Options with custom Spinner box -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="@string/extra_feed"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <FrameLayout
                                android:layout_width="150dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_spinner_box">

                                <Spinner
                                    android:id="@+id/spFeedLines"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:spinnerMode="dropdown"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="36dp"
                                    android:background="@android:color/transparent"
                                    android:textColor="@color/text_primary"/>

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="end|center_vertical"
                                    android:layout_marginEnd="10dp"
                                    android:src="@drawable/ic_arrow_down"
                                    app:tint="@color/text_secondary"
                                    android:contentDescription="Dropdown Arrow"
                                    android:clickable="false"
                                    android:focusable="false"/>
                            </FrameLayout>
                        </LinearLayout>

                        <!-- Print Contrast Slider -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/print_contrast"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:layout_marginBottom="10dp"
                            android:fontFamily="sans-serif-medium"/>

                        <SeekBar
                            android:id="@+id/sbContrast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="100"
                            android:progress="50"
                            android:thumbTint="@color/accent_blue"
                            android:progressTint="@color/accent_blue"
                            android:progressBackgroundTint="@color/border_glass"
                            android:layout_marginBottom="24dp"/>

                        <!-- System Print Service Enable -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnOpenPrintSettings"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:text="Enable System Print Service"
                            android:textColor="@color/accent_blue"
                            app:strokeColor="@color/accent_blue"
                            app:strokeWidth="1.5dp"
                            app:cornerRadius="25dp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ==================== TAB 4: SYSTEM LOGS ==================== -->
            <LinearLayout
                android:id="@+id/tabLayoutLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_glass"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/bg_slate_card"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_server"
                                app:tint="@color/accent_blue"
                                android:layout_marginEnd="12dp"
                                android:contentDescription="Logs"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="@string/activity_logs"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"/>
                            
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnClearLogs"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="Clear"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <!-- Monospace console log panel with border -->
                        <ScrollView
                            android:id="@+id/svLogs"
                            android:layout_width="match_parent"
                            android:layout_height="320dp"
                            android:background="#070A13"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tvLogs"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:text="[System info] Bridge dashboard ready.\n"
                                android:textColor="#00FFCC"
                                android:textSize="11sp"/>
                        </ScrollView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- FIXED FLOATING BOTTOM GLASS NAVIGATION DOCK -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_nav_dock"
        android:gravity="center"
        android:padding="4dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:layout_marginTop="8dp"
        android:elevation="6dp">
        
        <!-- Tab 1: Printer -->
        <LinearLayout
            android:id="@+id/btnTabPrinter"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            
            <ImageView
                android:id="@+id/ivTabPrinter"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_printer"
                app:tint="@color/accent_blue"/>
            
            <TextView
                android:id="@+id/tvTabPrinter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Printer"
                android:textSize="10sp"
                android:textColor="@color/accent_blue"
                android:textStyle="bold"
                android:layout_marginTop="1dp"
                android:fontFamily="sans-serif-medium"/>
            
            <!-- Sleek active capsule indicator -->
            <View
                android:id="@+id/vIndicatorPrinter"
                android:layout_width="16dp"
                android:layout_height="2.5dp"
                android:background="@color/accent_blue"
                android:layout_marginTop="3dp"
                android:visibility="visible"/>
        </LinearLayout>

        <!-- Tab 2: Server -->
        <LinearLayout
            android:id="@+id/btnTabServer"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            
            <ImageView
                android:id="@+id/ivTabServer"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_server"
                app:tint="@color/text_secondary"/>
            
            <TextView
                android:id="@+id/tvTabServer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Server"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="1dp"
                android:fontFamily="sans-serif"/>

            <!-- Sleek active capsule indicator -->
            <View
                android:id="@+id/vIndicatorServer"
                android:layout_width="16dp"
                android:layout_height="2.5dp"
                android:background="@color/accent_blue"
                android:layout_marginTop="3dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Tab 3: Settings -->
        <LinearLayout
            android:id="@+id/btnTabSettings"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            
            <ImageView
                android:id="@+id/ivTabSettings"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/text_secondary"/>
            
            <TextView
                android:id="@+id/tvTabSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="1dp"
                android:fontFamily="sans-serif"/>

            <!-- Sleek active capsule indicator -->
            <View
                android:id="@+id/vIndicatorSettings"
                android:layout_width="16dp"
                android:layout_height="2.5dp"
                android:background="@color/accent_blue"
                android:layout_marginTop="3dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Tab 4: Logs -->
        <LinearLayout
            android:id="@+id/btnTabLogs"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            
            <ImageView
                android:id="@+id/ivTabLogs"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_scan"
                app:tint="@color/text_secondary"/>
            
            <TextView
                android:id="@+id/tvTabLogs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logs"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="1dp"
                android:fontFamily="sans-serif"/>

            <!-- Sleek active capsule indicator -->
            <View
                android:id="@+id/vIndicatorLogs"
                android:layout_width="16dp"
                android:layout_height="2.5dp"
                android:background="@color/accent_blue"
                android:layout_marginTop="3dp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
