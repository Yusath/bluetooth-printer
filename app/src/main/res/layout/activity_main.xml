<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_slate_dark"
    android:padding="20dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER PANEL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_printer"
                    app:tint="@color/accent_blue"
                    android:layout_marginBottom="12dp"
                    android:contentDescription="@string/app_name"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Web &amp; TCP Print Bridge"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- SERVER SETTINGS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_glass"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/bg_slate_card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_server"
                            app:tint="@color/accent_blue"
                            android:layout_marginEnd="12dp"
                            android:contentDescription="@string/server_settings"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/server_settings"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <!-- Status Display -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/status_server"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tvServerStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stopped"
                            android:textStyle="bold"
                            android:textColor="@color/status_red"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Switches & Inputs -->
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/swStartServer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/enable_server"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        app:useMaterialThemeColors="false"
                        app:thumbTint="@color/accent_blue"
                        app:trackTint="@color/border_glass"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/swStartOnBoot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/start_on_boot"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        app:useMaterialThemeColors="false"
                        app:thumbTint="@color/accent_blue"
                        app:trackTint="@color/border_glass"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/server_port"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"/>

                        <EditText
                            android:id="@+id/etServerPort"
                            android:layout_width="100dp"
                            android:layout_height="40dp"
                            android:background="@drawable/border_glass"
                            android:gravity="center"
                            android:inputType="number"
                            android:text="6801"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:maxLength="5"
                            android:padding="8dp"
                            android:contentDescription="@string/server_port"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PRINTER CONNECTION CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_glass"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/bg_slate_card"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_scan"
                            app:tint="@color/accent_blue"
                            android:layout_marginEnd="12dp"
                            android:contentDescription="@string/printer_settings"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/printer_settings"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <!-- Status Display -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/status_printer"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tvPrinterStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Disconnected"
                            android:textStyle="bold"
                            android:textColor="@color/status_red"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/select_printer"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_bottom="8dp"
                        android:layout_marginBottom="8dp"/>

                    <!-- Spinner container -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/border_glass"
                        android:layout_marginBottom="16dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <Spinner
                            android:id="@+id/spPrinters"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:spinnerMode="dropdown"
                            android:textColor="@color/text_primary"/>
                    </FrameLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConnect"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/connect"
                        android:textColor="@color/bg_slate_dark"
                        app:backgroundTint="@color/accent_blue"
                        app:cornerRadius="24dp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTestPrint"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/test_print"
                        android:textColor="@color/accent_blue"
                        app:strokeColor="@color/accent_blue"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="24dp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
